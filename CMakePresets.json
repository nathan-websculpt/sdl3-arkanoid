{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows vcpkg (VS18 2026, x64-windows)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build-win-vcpkg",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_MODE": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-vcpkg-analyze",
      "inherits": "windows-vcpkg",
      "binaryDir": "${sourceDir}/out/build-win-vcpkg-analyze",
      "cacheVariables": {
        "ARKANOID_ENABLE_MSVC_ANALYZE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release",
      "targets": [
        "arkanoid"
      ]
    },
    {
      "name": "windows-vcpkg-release-tests",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release",
      "targets": [
        "arkanoid_tests"
      ]
    },
    {
      "name": "windows-vcpkg-debug-analyze",
      "configurePreset": "windows-vcpkg-analyze",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-vcpkg-debug-analyze",
      "configurePreset": "windows-vcpkg-analyze",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
